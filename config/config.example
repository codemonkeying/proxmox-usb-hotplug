# /etc/usb-hotplug/config
# Sourced by usb-mapping-daemon.sh at startup. Override the built-in defaults.

# Anchor PCI resource mapping — shared-* USB devices follow the VM that
# currently has this mapping attached. Typically a GPU but it's just a
# string match, so any PCI mapping works.
#
# The value must match the *name* you gave the mapping in the Proxmox GUI
# (Datacenter -> Resource Mappings -> PCI). The name is user-chosen, not
# derived from hardware — anything goes as long as it matches exactly.
#
# Example:  GPU_MAPPING="host1_gpu"
#
# Leave empty to disable shared-* routing (vm{ID}-* still works).
GPU_MAPPING=""

# Poll interval in seconds for the main device-change loop
INTERVAL=2
